{
  "name": "sell_exa",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "build": {
    "appId": "com.sellexa.app",
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/OIP.webp"
    },
    "asar": true
